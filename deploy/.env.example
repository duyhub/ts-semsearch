# Copy to .env in the repo root (next to docker-compose.yml) and edit as needed.
# Docker Compose auto-loads .env for the ${...} interpolation in the compose file.
# For plain local deployment you can skip this file entirely — the defaults hold.

# Deployment mode:
#   local        (default) self-contained bge-m3, no network needed after model download
#   local-first  prefer local bge-m3, fall back to Bedrock if the local model is broken
#   cloud        no local model — embeddings via AWS Bedrock (needs creds below)
SEMSEARCH_MODE=local

# ── Only for SEMSEARCH_MODE=cloud / local-first fallback (AWS Bedrock) ──
# Also uncomment the matching lines in docker-compose.yml so they pass through.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# SEMSEARCH_BEDROCK_REGION=ap-southeast-1
# SEMSEARCH_LLM_PARSE=off

# ── Optional Langfuse tracing on LLM calls ──
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
