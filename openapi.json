              },
              "date_spot_d1": {
                "summary": "Romantic date spot in District 1",
                "value": "nơi hẹn hò lãng mạn ở quận 1"
              },
              "pho_late_nearby": {
                "summary": "Phở open late, near me (use with lat/lon)",
                "value": "phở mở khuya gần đây"
              },
              "rooftop_view": {
                "summary": "Rooftop bar with a view",
                "value": "quán bar sân thượng ngắm cảnh đẹp"
              }
            }
          },
          {
            "name": "lat",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 90,
                  "minimum": -90
                },
                {
                  "type": "null"
                }
              ],
              "description": "WGS84 latitude; supply together with lon",
              "title": "Lat"
            },
            "description": "WGS84 latitude; supply together with lon",
            "examples": {
              "hcmc_d1": {
                "summary": "Bến Thành, District 1",
                "value": 10.7738
              }
            }
          },
          {
            "name": "lon",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 180,
                  "minimum": -180
                },
                {
                  "type": "null"
                }
              ],
              "description": "WGS84 longitude; supply together with lat",
              "title": "Lon"
            },
            "description": "WGS84 longitude; supply together with lat",
            "examples": {
              "hcmc_d1": {
                "summary": "Bến Thành, District 1",
                "value": 106.704
              }
            }
          },
          {
            "name": "radiusMeters",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional radius filter; requires both lat and lon",
              "title": "Radiusmeters"
            },
            "description": "Optional radius filter; requires both lat and lon"
          },
          {
            "name": "bbox",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Bbox"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Category"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "Max results; clamped to 1–20 (default 10)",
              "default": 10,
              "title": "Limit"
            },
            "description": "Max results; clamped to 1–20 (default 10)"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Response language hint",
              "default": "vi",
              "title": "Lang"
            },
            "description": "Response language hint"
          },
          {
            "name": "engine",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "full",
              "title": "Engine"
            }
          },
          {
            "name": "x-request-id",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Request-Id"
            }
          }
        ],
